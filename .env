# =============================================================
#  .env.local
#  Never commit this file. It is already in .gitignore by default.
#  Duplicate as .env.local on every machine / deployment environment.
# =============================================================

# ── Resend (email) ────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# The inbox that receives contact-form submissions.
# Must belong to a domain you have verified in your Resend account.
CONTACT_TO_EMAIL=info@kowalskiplumbing.ca

# ── Site (used in API route and metadata) ─────────────────
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://kowalskiplumbing.ca

# ── Optional: Google Maps embed (alternative to hardcoding) ──
# If set, this overrides contact.mapsEmbedUrl in client.ts.
# Leave blank to use the value in client.ts directly.
# NEXT_PUBLIC_MAPS_EMBED_URL=
